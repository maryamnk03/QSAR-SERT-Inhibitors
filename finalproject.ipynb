import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns
from sklearn.model_selection import train_test_split, cross_val_score, LeaveOneOut
from sklearn.linear_model import LinearRegression, Ridge
from sklearn.ensemble import RandomForestRegressor
from sklearn.svm import SVR
from sklearn.neural_network import MLPRegressor
from sklearn.preprocessing import StandardScaler
from sklearn.metrics import r2_score, mean_absolute_error, mean_squared_error
from sklearn.utils import shuffle
from rdkit import Chem
from rdkit.Chem import Descriptors, Lipinski, rdMolDescriptors
import warnings
warnings.filterwarnings('ignore')
SMILES Insertion
smiles_list = [
    "FC1=CC=C(C=C1)C2=CC(=CC(=C2)COCC3(CCNCC3)C4=CC=CC=C4)C(C(F)(F)F)(F)F",
    "FC1=CC=CC=C1C2=CC(=CC(=C2)COCC3(CCNCC3)C4=CC=CC=C4)C(C(F)(F)F)(F)F",
    "FC1=CC(=CC=C1)C2=CC(=CC(=C2)COCC3(CCNCC3)C4=CC=CC=C4)C(C(F)(F)F)(F)F",
    "FC1=CC=C(C=C1)C2=CC(=CC(=C2)COCC3(CCNCC3)C4=CC=CC=C4)C(C(F)(F)F)(F)F",
    "CC(C)C1=CC=CC=C1C2=CC(=CC(=C2)COCC3(CCNCC3)C4=CC=CC=C4)C(C(F)(F)F)(F)F",
    "CC(C)C1=CC(=CC=C1)C2=CC(=CC(=C2)COCC3(CCNCC3)C4=CC=CC=C4)C(C(F)(F)F)(F)F",
    "CC(C)C1=CC=C(C=C1)C2=CC(=CC(=C2)COCC3(CCNCC3)C4=CC=CC=C4)C(C(F)(F)F)(F)F",
    "N#CC1=CC=CC=C1C2=CC(=CC(=C2)COCC3(CCNCC3)C4=CC=CC=C4)C(C(F)(F)F)(F)F",
    "CN(C)C1=CC=CC=C1C2=CC(=CC(=C2)COCC3(CCNCC3)C4=CC=CC=C4)C(C(F)(F)F)(F)F",
]

pIC50 = [7.8952, 8.0215, 7.9310, 8.1855, 8.0070, 7.6785, 8.0295, 8.1943, 8.4814]

print(f" Number of compounds: {len(smiles_list)}")
print(f" pIC50 range: {min(pIC50)} – {max(pIC50)}")
Calculate Features From SMILES
def calculate_descriptors(smiles):
    mol = Chem.MolFromSmiles(smiles)
    if mol is None:
        return None
    return {
        'MolWt': Descriptors.MolWt(mol),
        'HeavyAtomCount': mol.GetNumHeavyAtoms(),
        'NumRotatableBonds': Descriptors.NumRotatableBonds(mol),
        'LogP': Descriptors.MolLogP(mol),
        'TPSA': Descriptors.TPSA(mol),
        'NumHDonors': Descriptors.NumHDonors(mol),
        'NumHAcceptors': Descriptors.NumHAcceptors(mol),
        'RingCount': rdMolDescriptors.CalcNumRings(mol),
        'AromaticRingCount': rdMolDescriptors.CalcNumAromaticRings(mol),
        'FractionCsp3': Lipinski.FractionCSP3(mol),
    }

X_list = []
y_list = []
for smiles, activity in zip(smiles_list, pIC50):
    desc = calculate_descriptors(smiles)
    if desc:
        X_list.append(desc)
        y_list.append(activity)

X = pd.DataFrame(X_list)
y = pd.Series(y_list)

print(f" Descriptors: {list(X.columns)}")
Preprocessing
# Remove constant features
constant_cols = [col for col in X.columns if X[col].std() == 0]
if constant_cols:
    X = X.drop(columns=constant_cols)
    print(f" Removed constant features: {constant_cols}")

# Remove highly correlated features (|r| > 0.95)
if X.shape[1] > 1:
    corr_matrix = X.corr().abs()
    upper = corr_matrix.where(np.triu(np.ones(corr_matrix.shape), k=1).astype(bool))
    to_drop = [col for col in upper.columns if any(upper[col] > 0.95)]
    if to_drop:
        X = X.drop(columns=to_drop)
        print(f" Removed highly correlated features: {to_drop}")

print(f" Final descriptors: {list(X.columns)}")
Test/Train Split
X_train, X_test, y_train, y_test = train_test_split(X, y, test_size=0.3, random_state=42)

scaler = StandardScaler()
X_train_scaled = scaler.fit_transform(X_train)
X_test_scaled = scaler.transform(X_test)

print(f" Training set: {len(X_train)} compounds")
print(f" Test set: {len(X_test)} compounds")
Define Models
models = {
    'Linear Regression': (LinearRegression(), False),
    'Ridge Regression': (Ridge(alpha=1.0), False),
    'Random Forest': (RandomForestRegressor(n_estimators=100, random_state=42), False),
    'Random Forest (tuned)': (RandomForestRegressor(n_estimators=200, max_depth=5, random_state=42), False),
    'SVM (RBF)': (SVR(kernel='rbf', C=1.0, epsilon=0.1), True),
    'SVM (tuned)': (SVR(kernel='rbf', C=10.0, epsilon=0.05, gamma='scale'), True),
    'Neural Network (2 layers)': (MLPRegressor(hidden_layer_sizes=(10,5), max_iter=1000, random_state=42), True),
    'Neural Network (1 layer)': (MLPRegressor(hidden_layer_sizes=(5,), max_iter=1000, random_state=42), True),
}
Train Models
results = []

for name, (model, need_scaling) in models.items():
    if need_scaling:
        model.fit(X_train_scaled, y_train)
        y_pred = model.predict(X_test_scaled)
    else:
        model.fit(X_train, y_train)
        y_pred = model.predict(X_test)
    
    r2 = r2_score(y_test, y_pred)
    mae = mean_absolute_error(y_test, y_pred)
    rmse = np.sqrt(mean_squared_error(y_test, y_pred))
    
    results.append({'Model': name, 'R²': r2, 'MAE': mae, 'RMSE': rmse})
    print(f"{name:30} | R²={r2:.4f} | MAE={mae:.4f} | RMSE={rmse:.4f}")
Y-radomization Test
def y_randomization(model, X, y, need_scaling=False, n_iter=20):
    # Real R² using 3‑fold CV
    if need_scaling:
        r2_real = cross_val_score(model, X, y, cv=3, scoring='r2').mean()
    else:
        r2_real = cross_val_score(model, X, y, cv=3, scoring='r2').mean()
    
    r2_random_list = []
    for i in range(n_iter):
        y_shuffled = shuffle(y, random_state=i)
        if need_scaling:
            r2_shuffled = cross_val_score(model, X, y_shuffled, cv=3, scoring='r2').mean()
        else:
            r2_shuffled = cross_val_score(model, X, y_shuffled, cv=3, scoring='r2').mean()
        r2_random_list.append(r2_shuffled)
    
    return r2_real, r2_random_list

best_rf = RandomForestRegressor(n_estimators=200, max_depth=5, random_state=42)
r2_real, r2_rand = y_randomization(best_rf, X_train, y_train, need_scaling=False, n_iter=20)

print(f" Real R² (3‑fold CV)  : {r2_real:.4f}")
print(f" Mean random R²       : {np.mean(r2_rand):.4f} ± {np.std(r2_rand):.4f}")
cRp2 = r2_real * (r2_real - np.mean(r2_rand))**0.5
print(f" cR²p                  : {cRp2:.4f}  (must be > 0.5)")
Leave‑One‑Out Cross‑Validation
# Leave-One-Out Cross-Validation for the best model (Random Forest tuned)
from sklearn.model_selection import LeaveOneOut, cross_val_score
from sklearn.ensemble import RandomForestRegressor

loo_rf = RandomForestRegressor(n_estimators=200, max_depth=5, random_state=42)
loo = LeaveOneOut()
loo_scores = cross_val_score(loo_rf, X, y, cv=loo, scoring='r2')

print(f" LOO-CV mean R²: {np.mean(loo_scores):.4f} ± {np.std(loo_scores):.4f}")
print(f" Individual scores: {[round(s, 3) for s in loo_scores]}")
Feature Importance (Random Forest)
rf_model = RandomForestRegressor(n_estimators=200, max_depth=5, random_state=42)
rf_model.fit(X_train, y_train)

imp_df = pd.DataFrame({
    'Descriptor': X.columns,
    'Importance': rf_model.feature_importances_
}).sort_values('Importance', ascending=False)

plt.figure(figsize=(8,5))
sns.barplot(data=imp_df, x='Importance', y='Descriptor', palette='coolwarm')
plt.title(' Feature Importance – Impact on pIC50 prediction')
plt.show()
Correlation Heatmap
plt.figure(figsize=(8,6))
sns.heatmap(X.corr(), annot=True, cmap='coolwarm', fmt='.2f', linewidths=0.5)
plt.title('Descriptor Correlation Matrix')
plt.show()
Save Results & Compare with Paper
df_results_final = pd.DataFrame(results)

with open("QSAR_Final_Results.txt", "w") as f:
    f.write("===== QSAR MODELING FINAL RESULTS =====\n\n")
    f.write("TABLE 1: Model Performance Comparison\n")
    f.write("=" * 70 + "\n")
    
    for idx, row in df_results_final.iterrows():
        f.write(f"{row['Model']:30} | R² = {row['R²']:10.4f} | MAE = {row['MAE']:.4f} | RMSE = {row['RMSE']:.4f}\n")
    
    f.write("\n" + "=" * 70 + "\n\n")
    f.write(f"Y-Randomization Test Results (Random Forest tuned):\n")
    f.write(f"  Real 3-fold CV R²: {r2_real:.4f}\n")
    f.write(f"  Mean random R²   : {np.mean(r2_rand):.4f} ± {np.std(r2_rand):.4f}\n")
    f.write(f"  cR²p             : {cRp2:.4f}  (must be > 0.5)\n\n")
    
    f.write(f"Leave-One-Out Cross-Validation (Random Forest tuned):\n")
    f.write(f"  Mean LOO R²: {np.mean(loo_scores):.4f} ± {np.std(loo_scores):.4f}\n\n")
    
    f.write("Comparison with Original Paper (Pharmaceuticals 2026):\n")
    f.write("  Paper best model (GA-MLR) : Test R^2 = 0.8516\n")

    best_model = df_results_final.loc[df_results_final['R²'].idxmax()]
    f.write(f"  Our best model ({best_model['Model']}) : Test R² = {best_model['R²']:.4f}\n")

print("✓ Results saved to QSAR_Final_Results.txt")

print("\n" + "="*60)
print(" FINAL SUMMARY - BEST MODEL PERFORMANCE")
print("="*60)
best_model = df_results_final.loc[df_results_final['R²'].idxmax()]
print(f"Best Model: {best_model['Model']}")
print(f"Test R²:    {best_model['R²']:.4f}")
print(f"Test MAE:   {best_model['MAE']:.4f}")
print(f"Test RMSE:  {best_model['RMSE']:.4f}")
print(f"cR²p:       {cRp2:.4f}")
print(f"LOO CV R²:  {np.mean(loo_scores):.4f}")
Final Summary Table
print("\n" + "="*60)
print(" FINAL SUMMARY FOR ALL MODELS")
print("="*60)
