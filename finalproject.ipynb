R² & MAE Comparison
import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns

data = {
    'Model': [
        'Random Forest',
        'Random Forest (tuned)',
        'SVM (tuned)',
        'SVM (RBF)',
        'Ridge Regression',
        'Linear Regression',
        'Neural Network (2 layers)',
        'Neural Network (1 layer)'
    ],
    'R²': [0.119382, 0.082923, -0.059175, -0.334956, -40.825042, -51.931039, -1429.079505, -3091.468206],
    'MAE': [0.137474, 0.142744, 0.148960, 0.150484, 0.916366, 1.012360, 8.037849, 7.231018]
}

df = pd.DataFrame(data)
df = df.sort_values('R²', ascending=False)

plt.figure(figsize=(14, 6))

plt.subplot(1, 2, 1)

bars = plt.barh(df['Model'], df['R²'], color='steelblue', edgecolor='black', alpha=0.8)

for i, model in enumerate(df['Model']):
    if model == 'Random Forest':
        bars[i].set_color('seagreen')
        bars[i].set_edgecolor('darkgreen')

plt.axvline(x=0, color='red', linestyle='--', linewidth=1.5, alpha=0.8)

min_r2 = df['R²'].min()
plt.xlim(min_r2 - 100, 0.3)

plt.xlabel('R² (higher is better)', fontsize=12)
plt.ylabel('Model', fontsize=12)
plt.title(' Model Comparison by R²', fontsize=14, fontweight='bold')
plt.grid(axis='x', linestyle='--', alpha=0.3)

for bar, r2 in zip(bars, df['R²']):
    if r2 > -100:
        plt.text(bar.get_width() + 5, bar.get_y() + bar.get_height()/2, 
                 f'{r2:.3f}', va='center', fontsize=9)


plt.subplot(1, 2, 2)

df_mae = df.sort_values('MAE', ascending=True)

bars2 = plt.barh(df_mae['Model'], df_mae['MAE'], color='coral', edgecolor='black', alpha=0.8)


for i, model in enumerate(df_mae['Model']):
    if model == 'Random Forest':
        bars2[i].set_color('seagreen')
        bars2[i].set_edgecolor('darkgreen')

plt.xlabel('MAE (lower is better)', fontsize=12)
plt.ylabel('Model', fontsize=12)
plt.title(' Model Comparison by MAE', fontsize=14, fontweight='bold')
plt.grid(axis='x', linestyle='--', alpha=0.3)

plt.xlim(0, df_mae['MAE'].max() + 1)


for bar, mae in zip(bars2, df_mae['MAE']):
    plt.text(bar.get_width() + 0.1, bar.get_y() + bar.get_height()/2, 
             f'{mae:.3f}', va='center', fontsize=9)

plt.tight_layout()
plt.show()
Residual Plot
rf_model = RandomForestRegressor(n_estimators=100, random_state=42)
rf_model.fit(X_train, y_train)
y_pred_train = rf_model.predict(X_train)
y_pred_test = rf_model.predict(X_test)

residuals_train = y_train - y_pred_train
residuals_test = y_test - y_pred_test

plt.figure(figsize=(8,4))
plt.scatter(y_pred_train, residuals_train, alpha=0.7, label='Training', color='blue')
plt.scatter(y_pred_test, residuals_test, alpha=0.7, label='Test', color='red')
plt.axhline(y=0, color='black', linestyle='--')
plt.xlabel('Predicted pIC50')
plt.ylabel('Residuals')
plt.title('Residual Plot - Random Forest')
plt.legend()
plt.show()
